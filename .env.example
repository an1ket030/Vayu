# Frontend (prefix VITE_)
VITE_WAQI_TOKEN=your_waqi_token_here
VITE_OWM_API_KEY=your_owm_key_here
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_BACKEND_URL=http://localhost:4000
VITE_ML_SERVICE_URL=http://localhost:8000

# Backend
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cleanair
REDIS_URL=redis://redis:6379
WAQI_TOKEN=your_waqi_token_here
OWM_API_KEY=your_owm_key_here
ORS_API_KEY=your_ors_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key
JWT_SECRET=your_jwt_secret_min_32_chars

# ML Service
PYTHONPATH=/app
OWM_API_KEY=your_owm_key_here
MODEL_PATH=/app/models/saved/xgboost_aqi.pkl
TRAINING_LAT=28.6139
TRAINING_LON=77.2090
